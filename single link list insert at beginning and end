#include <stdio.h>
#include <stdlib.h>

struct node
{
    int data;
    struct node *next;
};

struct node *head = NULL;

struct node* create(int value)
{
    struct node *nn = malloc(sizeof(struct node));

    nn->data = value;
    nn->next = NULL;

    return nn;
}

/* INSERT AT END */
void insert_end(int value)
{
    struct node *nn = create(value);

    if(head == NULL)
    {
        head = nn;
        return;
    }

    struct node *temp = head;

    while(temp->next != NULL)
    {
        temp = temp->next;
    }

    temp->next = nn;
}

/* INSERT AT BEGINNING */
void insert_begin(int value)
{
    struct node *nn = create(value);

    nn->next = head;
    head = nn;
}

/* DELETE BY VALUE */
void delete_value(int value)
{
    struct node *temp = head;
    struct node *prev = NULL;

    if(temp != NULL && temp->data == value)
    {
        head = temp->next;
        free(temp);
        return;
    }

    while(temp != NULL && temp->data != value)
    {
        prev = temp;
        temp = temp->next;
    }

    if(temp == NULL)
        return;

    prev->next = temp->next;
    free(temp);
}

/* DISPLAY */
void display()
{
    struct node *temp = head;

    while(temp != NULL)
    {
        printf("%d -> ", temp->data);
        temp = temp->next;
    }

    printf("NULL\n");
}

/* COUNT NODES */
int count()
{
    int c = 0;
    struct node *temp = head;

    while(temp != NULL)
    {
        c++;
        temp = temp->next;
    }

    return c;
}

int main()
{
    insert_end(10);
    insert_end(20);
    insert_end(30);
    insert_begin(5);
    insert_begin(1);

    printf("Linked List: ");
    display();

    printf("Count: %d\n", count());

    delete_value(20);

    printf("After deletion: ");
    display();

    return 0;
}
